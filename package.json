{
  "name": "taskwarrior-symphony",
  "version": "0.1.0",
  "description": "Symphony orchestrator adapted for Taskwarrior — a local, autonomous coding-agent daemon.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "symphony": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
